# Hexly's TrailBase server config (ADR-0032). Committed; runtime state
# (data/, secrets/, uploads/, …) is gitignored — see ./.gitignore.
email {}
server {
  application_name: "Hexly"
  logs_retention_sec: 604800
}
auth {
  # Short-lived JWT + 30-day opaque refresh token. Revocation is TTL-bounded
  # (revoke the refresh token; the live JWT expires within the hour) — this
  # supersedes the instant-revocation half of ADR-0004.
  auth_token_ttl_sec: 3600
  refresh_token_ttl_sec: 2592000

  # Closed user set (ADR-0004, preserved): no public sign-up. The /register
  # endpoint is rejected (403) and existing users still log in with a password.
  # Members are provisioned by an admin (see docs/agents/domain.md / README).
  disable_password_auth: true
}
jobs {}

# Worlds + Entities as Record APIs (#129, ADR-0032, ADR-0024). Owner happy path:
# every row is owner-scoped; owner_id is autofilled from the caller. The cascade
# share (member reads of `shared` Entities) is slice #5 — not yet expressed here.
record_apis {
  name: "worlds"
  table_name: "worlds"
  acl_authenticated: [CREATE, READ, UPDATE, DELETE]
  create_access_rule: "_USER_.id IS NOT NULL"
  read_access_rule: "_ROW_.owner_id = _USER_.id"
  update_access_rule: "_ROW_.owner_id = _USER_.id"
  delete_access_rule: "_ROW_.owner_id = _USER_.id"
  autofill_missing_user_id_columns: true
}

record_apis {
  name: "entities"
  table_name: "entities"
  acl_authenticated: [CREATE, READ, UPDATE, DELETE]
  create_access_rule: "_USER_.id IS NOT NULL"
  read_access_rule: "_ROW_.owner_id = _USER_.id"
  update_access_rule: "_ROW_.owner_id = _USER_.id"
  # The Home Entity is undeletable (ADR-0024): the DELETE rule excludes it.
  delete_access_rule: "_ROW_.owner_id = _USER_.id AND _ROW_.is_home = FALSE"
  autofill_missing_user_id_columns: true
}
