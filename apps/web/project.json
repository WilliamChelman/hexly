{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/web/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/web",
        "browser": "apps/web/src/main.ts",
        "tsConfig": "apps/web/tsconfig.app.json",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/web/public"
          },
          {
            "glob": "marcellus-latin-400-normal.woff2",
            "input": "node_modules/@fontsource/marcellus/files",
            "output": "fonts"
          },
          {
            "glob": "source-serif-4-latin-wght-normal.woff2",
            "input": "node_modules/@fontsource-variable/source-serif-4/files",
            "output": "fonts"
          }
        ],
        "styles": ["apps/web/src/styles.css"],
        "allowedCommonJsDependencies": ["@messageformat/core"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kb",
              "maximumError": "12kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "apps/web/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "web:build:production"
        },
        "development": {
          "buildTarget": "web:build:development"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "i18n-sync": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/public/assets/i18n/**/*.json",
        "{projectRoot}/tools/check-locale-sync.ts",
        "{projectRoot}/tools/tsconfig.json",
        "{projectRoot}/src/app/core/i18n/locale-key-sync.ts"
      ],
      "options": {
        "commands": [
          "tsc -p apps/web/tools/tsconfig.json --noEmit",
          "jiti apps/web/tools/check-locale-sync.ts"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false
      }
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false,
        "setupFiles": ["apps/web/src/test-setup.ts"]
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "web:build",
        "staticFilePath": "dist/apps/web/browser",
        "spa": true
      }
    }
  }
}
