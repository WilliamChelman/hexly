{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "types": ["node"],
    "outDir": "../../dist/out-tsc/web-e2e",
    "sourceMap": false,
    "allowJs": true
